# Database URL for local development (without Docker)
# Make sure PostgreSQL is installed and running on your machine
# Or use the Docker compose setup instead

# Option 1: Local PostgreSQL (if installed on Kali)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dflagger?schema=public"

# Option 2: Docker PostgreSQL (when running docker-compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dflagger?schema=public"

PORT=4000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production
