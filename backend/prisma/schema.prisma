generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

model User {
 id        String   @id @default(uuid())
 email     String   @unique
 password  String
 createdAt DateTime @default(now())
}

model SigmaRule {
 id          String   @id @default(uuid())
 title       String
 description String
 rule        Json
 createdAt   DateTime @default(now())
}

model YaraRule {
 id          String   @id @default(uuid())
 title       String
 description String
 rule        Json
 createdAt   DateTime @default(now())
}

model UseCase {
 id          String   @id @default(uuid())
 title       String
 description String
 mitre       String?
 createdAt   DateTime @default(now())
}
